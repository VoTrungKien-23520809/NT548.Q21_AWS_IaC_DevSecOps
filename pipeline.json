{
  "pipeline": {
    "name": "NT548-Lab2-CFn-Pipeline",
    "roleArn": "arn:aws:iam::851725513978:role/LabRole",
    "artifactStore": {
      "type": "S3",
      "location": "nt548-lab2-pipeline-851725513978"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "S3Source",
            "actionTypeId": {
              "category": "Source",
              "owner": "AWS",
              "provider": "S3",
              "version": "1"
            },
            "configuration": {
              "S3Bucket": "nt548-lab2-pipeline-851725513978",
              "S3ObjectKey": "cfn-source.zip",
              "PollForSourceChanges": "true"
            },
            "outputArtifacts": [
              { "name": "SourceArtifact" }
            ],
            "runOrder": 1
          }
        ]
      },
      {
        "name": "Deploy",
        "actions": [
          {
            "name": "CFnDeploy",
            "actionTypeId": {
              "category": "Deploy",
              "owner": "AWS",
              "provider": "CloudFormation",
              "version": "1"
            },
            "configuration": {
              "ActionMode": "CREATE_UPDATE",
              "StackName": "NT548-Lab2-Infra",
              "TemplatePath": "SourceArtifact::cloudformation/infrastructure.yaml",
              "Capabilities": "CAPABILITY_NAMED_IAM",
              "RoleArn": "arn:aws:iam::851725513978:role/LabRole",
              "ParameterOverrides": "{\"KeyName\":\"vockey\"}"
            },
            "inputArtifacts": [
              { "name": "SourceArtifact" }
            ],
            "runOrder": 1
          }
        ]
      }
    ],
    "version": 1
  }
}
