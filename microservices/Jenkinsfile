pipeline {
    agent any

    environment {
        BACKEND_IMAGE  = "nt548-backend"
        FRONTEND_IMAGE = "nt548-frontend"
        KUBECONFIG     = "/home/kienvo/.kube/config"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "✅ Source code checked out"
                sh 'ls -la'
            }
        }

        stage('Build Docker Images') {
            steps {
                echo "🔨 Building backend image..."
                sh "docker build -t ${BACKEND_IMAGE}:${BUILD_NUMBER} -t ${BACKEND_IMAGE}:latest microservices/backend/"
                echo "🔨 Building frontend image..."
                sh "docker build -t ${FRONTEND_IMAGE}:${BUILD_NUMBER} -t ${FRONTEND_IMAGE}:latest microservices/frontend/"
                echo "✅ Images built successfully"
                sh "docker images | grep nt548"
            }
        }

        stage('Test') {
            steps {
                echo "🧪 Running backend test..."
                sh """
                    docker run --rm --name test-backend -d -p 5001:5000 ${BACKEND_IMAGE}:latest
                    sleep 3
                    curl -f http://localhost:5001/health
                    echo "✅ Health check passed"
                    docker stop test-backend
                """
            }
        }

        stage('Security Scan - Trivy') {
            steps {
                echo "🔍 Running Trivy security scan..."
                sh """
                    which trivy || (curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin)
                    trivy image --exit-code 0 --severity HIGH,CRITICAL --no-progress ${BACKEND_IMAGE}:latest
                    echo "✅ Trivy scan completed"
                """
            }
        }

        stage('Load Images to Minikube') {
            steps {
                echo "📦 Loading images into minikube..."
                sh """
                    minikube image load ${BACKEND_IMAGE}:latest
                    minikube image load ${FRONTEND_IMAGE}:latest
                    echo "✅ Images loaded to minikube"
                """
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo "🚀 Deploying to Kubernetes..."
                sh """
                    kubectl apply -f microservices/backend/k8s-deployment.yaml
                    kubectl apply -f microservices/frontend/k8s-deployment.yaml
                    kubectl rollout status deployment/backend --timeout=90s
                    kubectl rollout status deployment/frontend --timeout=90s
                    echo "✅ Deployed successfully"
                """
            }
        }

        stage('Verify') {
            steps {
                echo "🔎 Verifying deployment..."
                sh """
                    kubectl get pods
                    kubectl get services
                    echo "✅ All pods running"
                """
            }
        }
    }

    post {
        success {
            echo "🎉 Pipeline SUCCEEDED!"
            sh "docker images | grep nt548"
        }
        failure {
            echo "❌ Pipeline FAILED - check logs above"
        }
        always {
            sh "docker container prune -f || true"
        }
    }
}
